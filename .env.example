# Конфигурация бота клубной воронки (club3-сценарий).
# Скопируйте этот файл в .env и впишите реальные значения.

# --- 1. Telegram ---
BOT_TOKEN=YOUR_BOT_TOKEN_HERE
ADMIN_ID=987654321                 # ваш Telegram ID для /admin

# --- 2. Канал ---
# CHANNEL_ID нужен для проверки подписки и обработки заявок на вступление.
# Бот должен быть АДМИНОМ канала, а инвайт-ссылка — типа "заявка на вступление".
CHANNEL_ID=-1002222222222
CHANNEL_LINK=https://t.me/+0npyyzG-yAoxYmMx
CHANNEL_NAME=Артём Низаев | Криптовалюта, Аналитика, Доход

# --- 3. Режим работы и поведение воронки ---
# BOT_MODE=1 -> воронка стартует сразу по /start, подписка предлагается в конце
# BOT_MODE=2 -> бот ждёт вступления в канал и пишет первым после заявки (standalone)
BOT_MODE=1
# Требование вступления; по умолчанию выводится из BOT_MODE (1->false, 2->true).
# Раскомментируйте, чтобы задать явно:
# CLUB_FLOW_REQUIRES_JOIN=true
# Автоматически одобрять заявки на вступление (актуально для режима 2)
AUTO_APPROVE_JOIN=true

# --- 4. Менеджер ("ГОЛОС КЛУБА") ---
CLOSER_USERNAME=nizaev_art
# CLUB_MANAGER_URL=https://t.me/nizaev_art   # по умолчанию строится из CLOSER_USERNAME

# --- 5. Тексты (необязательно; поддерживается \n) ---
# JOIN_WAIT_MESSAGE=Подпишись на канал и дождись подтверждения...
# START_MESSAGE=Добро пожаловать!...
# CLUB_STEP2_TITLE=<b>Как заработать в 2026?</b>
# CLUB_STEP2_MESSAGE=...
# CLUB_STEP3_MESSAGE=...
# NOT_ROBOT_BUTTON_TEXT=Я не робот
# VOICE_BUTTON_TEXT=ГОЛОС КЛУБА
# REVIEWS_BUTTON_TEXT=СМОТРЕТЬ ОТЗЫВЫ
# SUBSCRIBE_BUTTON_TEXT=Подписаться на канал

# --- 6. Медиа (необязательно; пути относительно папки бота) ---
# START_IMAGE=media/photo1.jpg
# REVIEWS_MEDIA=media/otzivi1.png,media/otzivi2.png,media/otzivi3.png,media/otzivi4.jpg,media/otzivi5.png
# REVIEWS_CAPTION=Отзывы участников клуба 👇

# --- 7. Keitaro PostBack (необязательно) ---
# Отправляется при вступлении в канал. {subid} и {status} подставляются автоматически.
KEITARO_POSTBACK_URL=
